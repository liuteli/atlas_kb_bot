# GITHUB atlas repo - READONLY
# Optional in the normal local-Repo-A + SSH workflow. Used only for future token-based fallback.
GITHUB_TOKEN=
GITHUB_REPO_URL=https://github.com/liuteli/atlas.git
GITHUB_DEFAULT_BRANCH=main

# GITHUB atlas_kb_bot repo
GITHUB_BOT_REPO_URL=https://github.com/liuteli/atlas_kb_bot.git
GITHUB_BOT_BRANCH=main

# Telegram
KB_TELEGRAM_BOT_TOKEN=
KB_ALLOWED_CHAT_IDS=

# CODEX / OpenAI
# Reserved for future Codex handoff / LLM review workers. Phase 1 does not call OpenAI directly.
OPENAI_MODEL_COMPLEX=gpt-5
OPENAI_MODEL_NORMAL=gpt-5
OPENAI_REASONING_EFFORT=high

# Knowledge roots
KB_KNOWLEDGE_VAULT_ROOT=/Users/liuteli/infra/knowledge/obsidian-main/atlas
KB_KNOWLEDGE_LOCAL_ROOT=/Users/liuteli/infra/knowledge_local/obsidian-main/atlas
KB_CHATGPT_EXPORT_ROOT=/Users/liuteli/infra/knowledge_local/obsidian-main/atlas/10_SOURCES_RAW/chatgpt-export

# Committed code cache / Atlas readonly fallback
KB_ATLAS_REPO_PATH=/Users/liuteli/infra/docker/postgres/atlas
KB_GITHUB_CACHE_ROOT=/Users/liuteli/infra/knowledge_local/obsidian-main/atlas/12_MIRRORS/github-committed-cache
KB_KEEP_COMMIT_SNAPSHOTS=1
KB_ALLOW_ATLAS_READONLY_FALLBACK=1

# Bot state and logs
KB_STATE_ROOT=/Users/liuteli/infra/knowledge_local/obsidian-main/atlas/99_SYSTEM/jobs/knowledge-bot
KB_REVIEW_OUTPUT_ROOT=/Users/liuteli/infra/knowledge_local/obsidian-main/atlas/99_SYSTEM/jobs/knowledge-bot/reviews
KB_LOG_ROOT=/Users/liuteli/infra/logs/knowledge-bot

# Optional archive root
KB_NAS_ARCHIVE_ROOT=/Users/liuteli/nas/datasets/knowledge
